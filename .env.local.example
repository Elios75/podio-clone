# Copy to .env.local and fill in from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: Podio workspace importer — source-side credentials
# (create an API key at podio.com/settings/api; the refresh token comes from
#  the password-flow token request you run yourself — see docs/PODIO-IMPORT.md)
# PODIO_CLIENT_ID=
# PODIO_CLIENT_SECRET=
# PODIO_REFRESH_TOKEN=

# Optional: inbound email domain shown on "Email to app/item" addresses
# (app address = base@domain, item address = base+i{itemNumber}@domain;
#  point your provider's inbound route at /api/inbound-email)
# NEXT_PUBLIC_INBOUND_DOMAIN=inbound.example.com

# Optional: Cloudflare Turnstile captcha for public webforms
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Optional: Stripe billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_TEAM=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_ENTERPRISE=
# STRIPE_RPC_PROOF=  # must match the 'stripe_rpc_proof' Vault secret

# Optional: OAuth file pickers (Phase 13b) — buttons appear per configured provider
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=          # Google Cloud OAuth client (web), Picker API enabled
# NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=     # Google Cloud API key for the Picker
# NEXT_PUBLIC_DROPBOX_APP_KEY=           # Dropbox app key (Chooser) with your domain allowed
# NEXT_PUBLIC_ONEDRIVE_CLIENT_ID=        # Azure app registration (SPA) client id

# Optional: Web push (Phase 14 PWA) — generate with `npx web-push generate-vapid-keys`
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Server-side VAPID keys live on Supabase (see docs/PWA.md):
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:... PUSH_WORKER_TOKEN=...
#   plus Vault secrets push_worker_url / push_worker_token

# Twilio SMS (Phase 13b) is configured on Supabase, not here:
#   supabase secrets set TWILIO_ACCOUNT_SID=... TWILIO_AUTH_TOKEN=... TWILIO_FROM=+1... SMS_WORKER_TOKEN=...
#   plus Vault secrets sms_worker_url / sms_worker_token (see docs/SMS.md)

# Optional: AI app builder (Phase 14)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: white-label portals (Phase 14)
# PORTAL_DOMAINS={"clients.example.com":"org-slug"}
