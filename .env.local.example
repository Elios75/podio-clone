# Copy to .env.local and fill in from Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: Cloudflare Turnstile captcha for public webforms
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Optional: Stripe billing
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_TEAM=
# STRIPE_PRICE_BUSINESS=
# STRIPE_PRICE_ENTERPRISE=
# STRIPE_RPC_PROOF=  # must match the 'stripe_rpc_proof' Vault secret

# Optional: AI app builder (Phase 14)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-5
